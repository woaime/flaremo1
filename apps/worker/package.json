{
  "name": "@flaremo/worker",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev --config ../../wrangler.jsonc --local",
    "deploy": "wrangler deploy --config ../../wrangler.jsonc",
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --config ../../vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@flaremo/contracts": "workspace:*",
    "@flaremo/db": "workspace:*",
    "@flaremo/domain": "workspace:*",
    "@flaremo/memos": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.10.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260627.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0",
    "wrangler": "^4.105.0"
  }
}
